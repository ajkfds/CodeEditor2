<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CodeEditor2.App"
			 RequestedThemeVariant="Dark"
			 >
	<!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
		<StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
		<Style Selector="MenuItem">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Padding" Value="8 2 8 2"/>
		</Style>
        <StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml"/>
		
		<!--kill all animations-->
		<Style Selector="Control">
			<Setter Property="Transitions">
				<Setter.Value>
					<Transitions />
				</Setter.Value>
			</Setter>
		</Style>
		
	</Application.Styles>


<Application.Resources>
    <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml"/>
        </ResourceDictionary.MergedDictionaries>

        <FontFamily x:Key="Tamazen">avares://CodeEditor2/Assets/font/tamazen-font/Tamzen8x15b.ttf#Tamzen</FontFamily>
        
        </ResourceDictionary>
</Application.Resources>

    <!--Application.Resources>

	<FontFamily x:Key="tamazen">avares://CodeEditor2/Assets/font/tamazen-font/Tamzen8x15b.ttf#tamazen8x15b</FontFamily>
    <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml"/>
        </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
    </Application.Resources--> 
	
</Application>
