<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:CodeEditor2.Views;assembly=CodeEditor2"
             xmlns:avaloniaEdit="using:AvaloniaEdit"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CodeEditor2.LLM.ChatControl"
             FontFamily="Yu Gothic UI, Meiryo, MS Gothic, sans-serif">
	<!--ListBox ItemsSource="{Binding Items}" Name="ListBox0"></ListBox-->
	<ScrollViewer Name="ChatScrollViewer">
		<FlyoutBase.AttachedFlyout>
			<views:PopupMenuFlyout Placement="AnchorAndGravity">
				<views:PopupMenuView
					Name="PopupMenu"
					Margin="0"
					Padding="0"
					FontSize="10"
					FontWeight="Normal"
					FontFamily="Cascadia Mono,Consolas,Menlo,Monospace"
				/>
			</views:PopupMenuFlyout>
		</FlyoutBase.AttachedFlyout>
	</ScrollViewer>
</UserControl>
